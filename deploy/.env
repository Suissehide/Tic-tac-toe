# Docker compose stack settings
COMPOSE_PROJECT_NAME='tic-tac-toe'
CONTAINER_REGISTRY_PREFIX=''
VERSION=0.0.1

#
APP_IMAGE_NAME=tic-tac-toe
LOG_LEVEL=debug
NODE_VERSION=24.12.0
NPM_VERSION=11.8.0

# Backend
TRAEFIK_BACK_HOST=tic-tac-toe-api.qwetle.fr
DATABASE_URL="postgres://postgres:postgres@tic-tac-toe-postgres:5432/tictactoe?schema=public"
HOST=0.0.0.0
JWT_SECRET="tictactoe-jwt"
JWT_REFRESH_SECRET="tictactoe-refresh"
JWT_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=180d
COOKIE_SECRET="tictactoe-cookie"
PORT=3000
FRONT_URL="https://tic-tac-toe.qwetle.fr"
CORS_ORIGIN="https://tic-tac-toe.qwetle.fr"

# Frontend
TRAEFIK_FRONT_HOST="tic-tac-toe.qwetle.fr"
VITE_ENVIRONMENT="development"
VITE_API_BASE_URL="https://tic-tac-toe-api.qwetle.fr"

# Postgres container configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB_NAME=tictactoe
POSTGRES_PORT=5432
