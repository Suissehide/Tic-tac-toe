datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

enum Role {
  NONE
  USER
  ADMIN
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  salt      String
  firstName String?
  lastName  String?
  role      Role    @default(NONE)
}

